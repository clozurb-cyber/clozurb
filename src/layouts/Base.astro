---
import '@fontsource/roboto/latin-400.css';
import '@fontsource/roboto/latin-700.css';
import '@fontsource/roboto/latin-900.css';
import '@fontsource/aleo/latin-400.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { path } from '../lib/paths';

type Props = {
  title: string;
  description?: string;
};

const {
  title,
  description = 'La boutique officielle des Zurbamateurs. Instruments, prestations, et trois minutes de silence.',
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · La Boutique des Zurbamateurs</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} · La Boutique des Zurbamateurs`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <link rel="icon" href={path('/favicon-32x32.png')} sizes="32x32" type="image/png" />
    <link rel="icon" href={path('/favicon-192x192.png')} sizes="192x192" type="image/png" />
    <link rel="apple-touch-icon" href={path('/apple-touch-icon.png')} />
  </head>
  <body>
    <a href="#content" class="skip">Aller au contenu</a>
    <Header />
    <main id="content">
      <slot />
    </main>
    <Footer />

    <style>
      .skip {
        position: absolute;
        top: -100px;
        left: var(--gutter);
        z-index: 100;
        padding: 0.75em 1.25em;
        background: var(--accent);
        color: var(--black);
        font-weight: 700;
        text-decoration: none;
        transition: top 0.15s ease;
      }

      .skip:focus {
        top: 0.5rem;
      }
    </style>
  </body>
</html>
