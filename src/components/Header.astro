---
import Logo from './Logo.astro';
import { path } from '../lib/paths';

const links = [
  { href: path('/'), label: 'Boutique' },
  { href: 'https://www.leszurbamateurs.com', label: 'Le vrai site' },
];

const isActive = (href: string) => Astro.url.pathname.replace(/\/$/, '') === href.replace(/\/$/, '');
---

<header class="header">
  <div class="page header__bar">
    <a href={path('/')} class="header__logo" aria-label="Accueil de la boutique">
      <Logo size="1.1rem" text="clozurb" />
    </a>

    <nav class="header__nav" aria-label="Navigation principale">
      {
        links.map(({ href, label }) => (
          <a href={href} class="header__link" aria-current={isActive(href) ? 'page' : undefined}>
            {label}
          </a>
        ))
      }

      <a
        href={path('/panier')}
        class="header__cart"
        aria-current={isActive(path('/panier')) ? 'page' : undefined}
      >
        Panier
        <span class="header__badge" data-cart-count hidden></span>
      </a>
    </nav>
  </div>
</header>

<script>
  import { subscribe, count } from '../scripts/cart';

  const badge = document.querySelector<HTMLElement>('[data-cart-count]');

  if (badge) {
    let previous: number | null = null;

    subscribe(() => {
      const total = count();

      badge.textContent = String(total);
      badge.hidden = total === 0;

      if (previous !== null && total > previous) {
        badge.removeAttribute('data-bump');
        void badge.offsetWidth;
        badge.setAttribute('data-bump', '');
      }

      previous = total;
    });

    badge.addEventListener('animationend', () => badge.removeAttribute('data-bump'));
  }
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: var(--white);
    border-bottom: 3px solid var(--black);
  }

  .header__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.75rem;
  }

  .header__logo {
    display: inline-flex;
    text-decoration: none;
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: clamp(0.6rem, 2vw, 1.5rem);
  }

  .header__link {
    display: none;
    font-family: var(--font-title);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    color: var(--black);
    padding-block: 0.25em;
    border-bottom: 3px solid transparent;
  }

  @media (min-width: 34em) {
    .header__link {
      display: inline-block;
    }
  }

  .header__link:hover,
  .header__link[aria-current='page'] {
    color: var(--black);
    border-bottom-color: var(--red);
  }

  .header__cart {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 44px;
    padding: 0.5em 0.9em;
    background: var(--black);
    color: var(--white);
    font-family: var(--font-title);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
  }

  .header__cart:hover {
    background: var(--red);
    color: var(--white);
  }

  .header__badge {
    display: inline-grid;
    place-items: center;
    min-width: 1.5em;
    height: 1.5em;
    padding-inline: 0.3em;
    background: var(--accent);
    color: var(--black);
    border-radius: 999px;
    font-size: 0.75rem;
  }

  .header__badge[data-bump] {
    animation: bump 0.35s ease;
  }

  @keyframes bump {
    0% {
      transform: scale(1);
    }
    40% {
      transform: scale(1.5) rotate(-8deg);
    }
    100% {
      transform: scale(1);
    }
  }
</style>
