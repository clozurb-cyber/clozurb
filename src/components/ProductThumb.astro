---
import { Image } from 'astro:assets';
import type { Product } from '../data/products';
import { productImageAsset } from '../lib/images';
import { productImage } from '../lib/paths';

type Props = {
  product: Product;
  eager?: boolean;
};

const { product, eager = false } = Astro.props;
const asset = productImageAsset(product.image);
const loading = eager ? 'eager' : 'lazy';
---

<div class="thumb">
  {
    asset ? (
      <Image
        class="thumb__img"
        src={asset}
        alt={product.name}
        widths={[240, 400, 800]}
        sizes="(min-width: 40em) 400px, 50vw"
        format="webp"
        loading={loading}
        decoding="async"
      />
    ) : (
      <img
        class="thumb__img"
        src={productImage(null)}
        alt=""
        width="400"
        height="300"
        loading={loading}
        decoding="async"
      />
    )
  }
</div>

<style>
  .thumb {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: radial-gradient(circle at 50% 42%, #911a29 0%, #0a0000 80%);
    border-bottom: 3px solid var(--black);
  }

  .thumb::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(circle at 50% 42%, #9e1a2b 0%, #0a0000 80%);
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .thumb__img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  :global(.card:hover) .thumb::before {
    opacity: 1;
  }

  :global(.card:hover) .thumb__img {
    transform: scale(1.06);
  }
</style>
