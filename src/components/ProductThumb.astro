---
import type { Product } from '../data/products';
import { productImage } from '../lib/paths';

type Props = {
  product: Product;
  eager?: boolean;
};

const { product, eager = false } = Astro.props;
---

<div class="thumb">
  <img
    class="thumb__img"
    src={productImage(product.image)}
    alt={product.image ? product.name : ''}
    width="400"
    height="300"
    loading={eager ? 'eager' : 'lazy'}
    decoding="async"
  />
</div>

<style>
  .thumb {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--black);
    border-bottom: 3px solid var(--black);
  }

  .thumb__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  :global(.card:hover) .thumb__img {
    transform: scale(1.06);
  }
</style>
